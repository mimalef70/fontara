{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      ".github/**/*.yml",
      "components.json",
      "package.json",
      "pnpm-workspace.yaml",
      "postcss.config.js",
      "src/**/*.html",
      "src/**/*.json",
      "src/**/*.ts",
      "src/**/*.tsx",
      "tailwind.config.js",
      "tasks/**/*.js",
      "tests/**/*.mjs",
      "tests/**/*.ts",
      "!build",
      "!node_modules"
    ]
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "asNeeded",
      "trailingCommas": "none",
      "bracketSameLine": true
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  }
}
