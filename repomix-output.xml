import assert from "node:assert/strict"
import test, { afterEach } from "node:test"

import {
  ensureStorageValues,
  mergeWebsiteLists,
  normalizeCustomFontList
} from "../../src/background/storage-manager"
import { DEFAULT_VALUES, STORAGE_KEYS } from "../../src/config/storage"
