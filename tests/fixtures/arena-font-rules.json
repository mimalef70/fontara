{
  "site": "arena",
  "cssFile": "assets/styles/arena.css",
  "fallbackPrefix": "--fontara-arena",
  "groups": [
    {
      "selectors": [":root", "html"],
      "fallbackName": "times-root",
      "fontFamily": "Times"
    },
    {
      "selectors": [
        ".body-base",
        ".prose",
        "html.m-0.h-svh.w-full > body.font-sans.__variable_697da2.__variable_3916eb > textarea"
      ],
      "fallbackName": "basel-grotesk-ui",
      "fontFamily": "baselGrotesk, \"baselGrotesk Fallback\", ui-sans-serif, system-ui, sans-serif"
    },
    {
      "selectors": [".font-heading", "h2"],
      "fallbackName": "martina-heading",
      "fontFamily": "martinaPlantijn, \"martinaPlantijn Fallback\", ui-serif, Georgia, Cambria, \"Times New Roman\", Times, serif"
    },
    {
      "matchedSelector": ".font-mono",
      "fallbackName": "basel-grotesk-mono",
      "fontFamily": "baselGroteskMono, \"baselGroteskMono Fallback\", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace"
    },
    {
      "matchedSelector": ".font-sans",
      "fallbackName": "basel-grotesk-emoji-ui",
      "fontFamily": "baselGrotesk, \"baselGrotesk Fallback\", ui-sans-serif, system-ui, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\", \"Segoe UI Symbol\", \"Noto Color Emoji\""
    },
    {
      "matchedSelector": ".prose :where(p, ul, ol, li, blockquote):not(:where([class~=\"not-prose\"], [class~=\"not-prose\"] *))",
      "fallbackName": "inter-prose",
      "fontFamily": "Inter, \"Inter Fallback\", ui-sans-serif, system-ui, sans-serif"
    }
  ],
  "ignoredSelectors": [],
  "ignoredSelectorPatterns": []
}
