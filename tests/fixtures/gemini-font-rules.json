{
  "site": "gemini",
  "cssFile": "assets/styles/gemini.css",
  "fallbackPrefix": "--fontara-gemini",
  "groups": [
    {
      "selectors": [
        ".actions-container-v2 .buttons-container-v2 .menu-button-wrapper",
        ".gds-body-l",
        ".gds-body-m",
        ".gds-body-s",
        ".gds-label-l",
        ".gds-title-l-emphasized",
        ".markdown-main-panel",
        ".markdown",
        ".ql-container",
        "rich-textarea .ql-editor.ql-blank::before"
      ],
      "fallbackName": "google-sans-flex-ui",
      "fontFamily": "\"Google Sans Flex\", \"Google Sans\", \"Helvetica Neue\", sans-serif"
    },
    {
      "matchedSelector": ".gb_Eb",
      "fallbackName": "roboto-ui",
      "fontFamily": "Roboto, Arial, sans-serif",
      "sourceDeclaration": {
        "property": "font",
        "value": "13px / 27px Roboto, Arial, sans-serif"
      }
    },
    {
      "matchedSelector": ".gb_Jd",
      "fallbackName": "google-sans-text-ui",
      "fontFamily": "\"Google Sans Text\", Roboto, Helvetica, Arial, sans-serif"
    },
    {
      "matchedSelector": ".mat-mdc-button",
      "fallbackName": "material-text-button",
      "fontFamily": "var(--mat-button-text-label-text-font, var(--mat-sys-label-large-font))"
    },
    {
      "matchedSelector": ".mat-mdc-unelevated-button",
      "fallbackName": "material-filled-button",
      "fontFamily": "var(--mat-button-filled-label-text-font, var(--mat-sys-label-large-font))"
    },
    {
      "matchedSelector": ".mdc-list-item__primary-text",
      "fallbackName": "material-list-primary",
      "fontFamily": "var(--mat-list-list-item-label-text-font, var(--mat-sys-body-large-font))"
    },
    {
      "matchedSelector": ".mdc-list-item--with-trailing-meta .mdc-list-item__end",
      "fallbackName": "material-list-meta",
      "fontFamily": "var(--mat-list-list-item-trailing-supporting-text-font, var(--mat-sys-label-small-font))"
    }
  ],
  "ignoredSelectors": [
    {
      "matchedSelector": ".google-symbols",
      "reason": "icon-font",
      "fontFamily": "\"Google Symbols\""
    },
    {
      "matchedSelector": ".lumi-symbols",
      "reason": "icon-font",
      "fontFamily": "\"Luminous Symbols\""
    },
    {
      "matchedSelector": "mat-icon.lm-icon-l",
      "reason": "icon-font",
      "fontFamily": "\"Luminous Symbols\""
    },
    {
      "matchedSelector": "mat-icon.lm-icon-m",
      "reason": "icon-font",
      "fontFamily": "\"Luminous Symbols\""
    },
    {
      "matchedSelector": "mat-icon.lm-icon-s",
      "reason": "icon-font",
      "fontFamily": "\"Luminous Symbols\""
    }
  ]
}
